        "label": "Baujahr",
        "name": "project_year",
        "type": "number"
      },
      {
        "key": "field_project_category",
        "label": "Kategorie",
        "name": "project_category",
        "type": "select",
        "choices": {
          "dachsanierung": "Dachsanierung",
          "neubau": "Neubau",
          "flachdach": "Flachdach",
          "fassadenverkleidung": "Fassadenverkleidung",
          "balkonabdichtung": "Balkonabdichtung"
        }
      },
      {
        "key": "field_project_gallery",
