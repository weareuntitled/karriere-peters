[
  {
    "key": "group_service",
    "title": "Dienstleistung Details",
    "fields": [
      {
        "key": "field_service_icon",
        "label": "Icon",
        "name": "service_icon",
        "type": "text",
        "instructions": "z.B. fa-roof, fa-tools, fa-home"
      },
      {
        "key": "field_service_short_desc",
        "label": "Kurzbeschreibung",
        "name": "service_short_desc",
        "type": "text"
      },
      {
        "key": "field_service_order",
        "label": "Sortierung",
        "name": "service_order",
        "type": "number"
      }
    ],
    "location": [
      [
        {
          "param": "post_type",
          "operator": "==",
          "value": "service"
        }
      ]
    ]
  },
  {
