---
import { stellen, site } from '../data';
const levelLabel = { erfahren: 'Erfahren', azubi: 'Azubi', montage: 'Montage' };
---
<section class="section section--border-top" id="stellen">
  <div class="wrap">
    <div class="section-header" style="margin:0 auto 40px; text-align:center">
      <span class="pill-badge pill-badge--accent" style="margin:0 auto">Jetzt bewerben</span>
      <h2 class="section-title" style="margin-top:24px">Offene Stellen in Kühbach</h2>
      <p class="section-body" style="margin:16px auto 0">Drei Positionen, drei starke Teams, ein gemeinsames Ziel: Handwerkskunst auf höchstem Niveau. Wähle deine Chance und werde Teil der Spenglerei Peters Familie.</p>
    </div>
    <div class="jobs-grid reveal">
      {stellen.map((job) => (
        <a href={`/stellen/${job.slug}`} class={`job-card job-card--${job.level} stagger`}>
          <div class="job-card__body">
            <div class="job-card__head">
              <span class="job-card__badge">{levelLabel[job.level]}</span>
              <span class="job-card__salary">{job.salary_range}</span>
            </div>
            <h3 class="job-card__title">{job.title}</h3>
            <p class="job-card__desc">{job.short_description}</p>
            <div class="job-card__location">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>{job.location}</span>
            </div>
          </div>
          <div class="job-card__foot">
            <span class="btn btn--primary" style="width:100%">Details ansehen</span>
          </div>
        </a>
      ))}
    </div>
    <div style="margin-top:32px; text-align:center">
      <p style="font-size:0.875rem; color:var(--ink-muted)">
        Keine passende Stelle dabei? <a href="#bewerbung" style="font-weight:600;color:var(--accent);text-decoration:underline">Bewirb dich trotzdem →</a>
      </p>
    </div>
  </div>
</section>