---
import { site } from '../data';
const selected = [
  { value: '', label: 'Bitte wählen' },
  { value: 'Spengler (m/w/d)', label: 'Spengler (m/w/d)' },
  { value: 'Folientechniker (m/w/d)', label: 'Folientechniker (m/w/d)' },
  { value: 'Dachdecker (m/w/d)', label: 'Dachdecker (m/w/d)' },
  { value: 'Initiativbewerbung', label: 'Initiativbewerbung' },
];
---
<section class="section section--border-top" id="bewerbung">
  <div class="wrap" style="max-width:720px">
    <div class="section-header" style="text-align:center; margin:0 auto">
      <span class="section-eyebrow">Bewerbung</span>
      <h2 class="section-title">In 2 Minuten beworben</h2>
      <p class="section-body" style="margin:12px auto 0">Kein langes Anschreiben nötig. Füll einfach das Formular aus. Wir melden uns persönlich bei dir zurück.</p>
    </div>
    <div class="form-card reveal" style="margin-top:36px">
      <form id="form" class="form-grid" action={site.webformEndpoint} method="POST" enctype="multipart/form-data">
        <input type="hidden" name="access_key" value={site.webformAccessKey} />
        <input type="hidden" name="subject" value="Bewerbung Spenglerei Peters" />
        <input type="hidden" name="from_name" value="Karriere-Site" />
        <input type="text" name="_honey" style="display:none" />
        <div class="form-group">
          <label for="vorname">Name <span class="required">*</span></label>
          <input id="vorname" name="vorname" required placeholder="Max Mustermann" autocomplete="name" />
        </div>
        <div class="form-group">
          <label for="email">E-Mail <span class="required">*</span></label>
          <input id="email" name="email" type="email" required placeholder="max@beispiel.de" autocomplete="email" />
        </div>
        <div class="form-group">
          <label for="phone">Telefon</label>
          <input id="phone" name="phone" type="tel" placeholder="0170 1234567" autocomplete="tel" />
        </div>
        <div class="form-group">
          <label for="position">Position <span class="required">*</span></label>
          <select id="position" name="position" required>
            {selected.map((o) => <option value={o.value} selected={o.value === ''}>{o.label}</option>)}
          </select>
        </div>
        <div class="form-group">
          <label for="experience">Berufserfahrung</label>
          <select id="experience" name="experience">
            <option value="">Bitte wählen</option>
            <option>Berufseinsteiger / Azubi</option>
            <option>1–3 Jahre</option>
            <option>3–10 Jahre</option>
            <option>Über 10 Jahre</option>
            <option>Quereinsteiger</option>
          </select>
        </div>
        <div class="form-group">
          <label for="availability">Verfügbar ab</label>
          <input id="availability" name="availability" placeholder="z. B. sofort" />
        </div>
        <div class="form-group form-group--full">
          <label for="anhang">Lebenslauf (PDF)</label>
          <label for="anhang" class="file-upload" id="file-label">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:20px;height:20px;color:var(--accent)"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            <span>Datei auswählen oder hierher ziehen</span>
            <span class="file-upload__hint">PDF, max. 5 MB</span>
          </label>
          <input id="anhang" name="anhang" type="file" accept=".pdf" class="file-input" />
        </div>
        <div class="form-group form-group--full">
          <label for="nachricht">Nachricht</label>
          <textarea id="nachricht" name="nachricht" placeholder="Erzähl uns kurz etwas über dich…"></textarea>
        </div>
        <div class="form-group form-group--full" style="flex-direction:row; align-items:center; gap:8px; display:flex; text-transform:none; letter-spacing:normal; font-weight:400; font-size:0.875rem">
          <input type="checkbox" id="dsgvo" name="dsgvo" required style="width:auto" />
          <label for="dsgvo" style="text-transform:none; letter-spacing:normal; font-weight:400; color:var(--ink-soft)">Ich habe die <a href="/datenschutz" style="text-decoration:underline;color:var(--accent)">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zu.</label>
        </div>
        <div class="form-group form-group--full" style="display:flex; flex-direction:row; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap">
          <button type="submit" class="btn btn--primary btn--lg" id="submit-btn">Bewerbung absenden</button>
          <p style="font-size:0.75rem; color:var(--ink-muted); margin:0">Mit dem Absenden stimmst du der Verarbeitung deiner Daten zur Bearbeitung der Bewerbung zu.</p>
        </div>
      </form>
      <div id="success" style="display:none; padding:24px 0; text-align:center" role="status" aria-live="polite">
        <h3 style="font-family:Manrope,sans-serif;font-size:1.25rem;font-weight:700;margin:0">Bewerbung eingegangen!</h3>
        <p style="color:var(--ink-soft);margin:8px 0 0">Danke für Deine Bewerbung. Wir melden uns innerhalb von 12 Stunden bei Dir zurück.</p>
      </div>
      <div id="error" style="display:none; padding:24px 0; text-align:center" role="status" aria-live="polite">
        <h3 style="font-family:Manrope,sans-serif;font-size:1.25rem;font-weight:700;margin:0">Fehler beim Senden</h3>
        <p style="color:var(--ink-soft);margin:8px 0 0">Bitte versuch es nochmal oder schreib uns direkt an <a href={"mailto:"+site.email} style="text-decoration:underline;color:var(--accent)">{site.email}</a>.</p>
      </div>
    </div>
    <p style="margin-top:16px; font-size:0.875rem; color:var(--ink-muted); text-align:center">
      Oder ruf direkt an: <a href={`tel:${site.phone.replace(/\s/g,'')}`} style="text-decoration:underline;color:var(--accent)">{site.phone}</a>
    </p>
    <script>
      var fileInput = document.getElementById('anhang');
      var fileLabel = document.getElementById('file-label');
      if (fileInput && fileLabel) {
        fileInput.addEventListener('change', function() {
          if (this.files && this.files.length > 0) {
            fileLabel.querySelector('span').textContent = this.files[0].name;
            fileLabel.classList.add('file-upload--active');
          }
        });
        fileLabel.addEventListener('dragover', function(e) { e.preventDefault(); this.classList.add('file-upload--active'); });
        fileLabel.addEventListener('dragleave', function() { this.classList.remove('file-upload--active'); });
        fileLabel.addEventListener('drop', function(e) {
          e.preventDefault(); this.classList.remove('file-upload--active');
          if (e.dataTransfer.files.length > 0) { fileInput.files = e.dataTransfer.files; }
        });
      }
      document.getElementById('form')?.addEventListener('submit', async function(e) {
        e.preventDefault();
        var btn = document.getElementById('submit-btn');
        btn.disabled = true;
        btn.textContent = 'Wird gesendet…';
        var fd = new FormData(this);
        try {
          var r = await fetch(this.action, { method: 'POST', body: fd });
          var d = await r.json();
          if (d.success) {
            this.style.display = 'none';
            document.getElementById('success').style.display = 'block';
          } else {
            document.getElementById('error').style.display = 'block';
          }
        } catch {
          document.getElementById('error').style.display = 'block';
        }
        btn.disabled = false;
        btn.textContent = 'Bewerbung absenden';
      });
    </script>
  </div>
</section>
