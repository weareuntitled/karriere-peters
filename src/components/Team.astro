---
---
<section class="section section--card" id="team">
  <div class="wrap" style="max-width:900px">
    <div class="section-header" style="text-align:center; margin:0 auto">
      <span class="section-eyebrow">Team</span>
      <h2 class="section-title">Lerne uns kennen</h2>
      <p class="section-body" style="margin:12px auto 0">Das bist Du in ein paar Wochen. Norbert und sein Team freuen sich auf Verstärkung.</p>
    </div>
    <figure class="team-figure reveal" style="margin:32px 0 0">
      <img src="/screen009430-d-1.jpg" alt="Team Spenglerei Peters" class="team-img" />
      <figcaption class="team-caption">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;flex:none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Dieselstraße 10 · Kühbach
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .team-figure { margin: 0; border-radius: var(--radius-xl); overflow: hidden; box-shadow: 0 8px 28px rgba(0,0,0,0.08); }
  .team-img { width: 100%; height: auto; display: block; }
  .team-caption {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    padding: 12px 16px; background: var(--bg); border-top: 1px solid var(--line);
    font-size: 0.8125rem; color: var(--ink-muted);
  }
  .team-caption svg { color: var(--accent); }
</style>