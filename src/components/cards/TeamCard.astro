---
interface Props {
  name: string;
  role: string;
  image: string;
  cert?: string;
}
const { name, role, image, cert } = Astro.props;
const imgPath = image.startsWith('/') ? image : `/images/${image}`;
---
<article class="sp-team-card">
  <div class="sp-team-avatar">
    <img src={imgPath} alt={name} loading="lazy" />
  </div>
  <div class="sp-team-info">
    <span class="sp-team-badge">Inhaber</span>
    <h3>{name}</h3>
    <p>{role}</p>
    {cert && (
      <div class="sp-team-cert">
        <span class="material-symbols-outlined">verified</span>
        {cert}
      </div>
    )}
  </div>
</article>

<style>
  .sp-team-card {
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.8);
    border-radius: 16px;
    padding: 32px;
    box-shadow: 0 8px 32px rgba(0, 113, 188, 0.08);
    transition: all 0.3s ease;
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }

  .sp-team-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0, 113, 188, 0.12); }

  .sp-team-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid rgba(0, 113, 188, 0.2);
  }

  .sp-team-avatar img { width: 100%; height: 100%; object-fit: cover; }

  .sp-team-info { flex: 1; }

  .sp-team-badge {
    display: inline-block;
    padding: 4px 12px;
    background: #d1e4ff;
    color: #00497c;
    border-radius: 9999px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .sp-team-card h3 {
    font-family: 'DM Sans', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: #1a1c1e;
    margin-bottom: 8px;
  }

  .sp-team-card p {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    color: #404751;
    margin: 0;
  }

  .sp-team-cert {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 12px;
    padding: 6px 12px;
    background: rgba(0, 113, 188, 0.1);
    border-radius: 9999px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: #0071bc;
  }

  .sp-team-cert .material-symbols-outlined { font-size: 16px; }

  @media (max-width: 640px) {
    .sp-team-avatar { width: 80px; height: 80px; }
  }

  @media (max-width: 480px) {
    .sp-team-avatar { width: 64px; height: 64px; }
  }

  @media (max-width: 768px) {
    .sp-team-card { padding: 24px; flex-direction: column; align-items: center; text-align: center; }
    .sp-team-cert { margin: 12px auto 0; }
  }

  @media (max-width: 640px) { .sp-team-card { padding: 20px; } }
  @media (max-width: 480px) { .sp-team-card { padding: 16px; border-radius: 12px; } }

  @media (max-width: 768px) {
    .sp-team-card h3 { font-size: 18px; }
  }

  @media (max-width: 480px) {
    .sp-team-card h3 { font-size: 16px; }
    .sp-team-card p { font-size: 13px; }
    .sp-team-badge { font-size: 11px; }
  }
</style>
