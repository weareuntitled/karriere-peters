---
import { site } from '../data';
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="wrap">
    <div class="footer__grid">
      <div class="footer__left">
        <p><strong>Spenglermeisterbetrieb Peters GmbH</strong><br>
        Dieselstraße 10 86556 Kühbach, Deutschland<br>
        <strong>Tel:</strong> {site.phone}<br>
        <strong>Fax:</strong> 08251 82948<br>
        <strong>Email:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></p>
      </div>
      <div class="footer__center">
        <h3 class="footer__title">Links</h3>
        <ul class="footer__links">
          <li><a href={site.websiteUrl}>Job / Career</a></li>
          <li><a href={`${site.websiteUrl}/contact-two/`}>Contact info</a></li>
          <li><a href={`${site.websiteUrl}/cookie-policy-eu/`}>Cookie Policy (EU)</a></li>
        </ul>
      </div>
      <div class="footer__right">
        <img src="/peters-logo.png" alt={`${site.name} Logo`} class="footer__logo" width="160" height="60" />
      </div>
    </div>
    <div class="footer__bottom">
      <span>&copy; {year} {site.name}. Alle Rechte vorbehalten.</span>
    </div>
  </div>
</footer>
