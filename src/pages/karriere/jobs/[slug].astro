---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/layout/Navbar.astro';
import Footer from '../../../components/layout/Footer.astro';
import GlassButton from '../../../components/ui/GlassButton.astro';
import GlassBadge from '../../../components/ui/GlassBadge.astro';
import TypebotEmbed from '../../../components/forms/TypebotEmbed.astro';

export async function getStaticPaths() {
  const jobs = await getCollection('jobs');
  return jobs.map((job) => ({
    params: { slug: job.slug },
    props: { job },
  }));
}

const { job } = Astro.props;
const { Content } = await job.render();
---
<BaseLayout title={`${job.data.title} | Karriere`}>
  <Navbar variant="minimal" />
  <main class="job-detail">
    <div class="job-detail-header">
      <a href="/karriere" class="back-link">
        <span class="material-symbols-outlined">arrow_back</span>
        Alle Stellen
      </a>
      <GlassBadge>{job.data.type}</GlassBadge>
    </div>
    <div class="job-detail-content">
      <div class="job-detail-main">
        <h1>{job.data.title}</h1>
        <div class="job-meta">
          <span class="meta-item">
            <span class="material-symbols-outlined">location_on</span>
            {job.data.location}
          </span>
          <span class="meta-item">
            <span class="material-symbols-outlined">schedule</span>
            {job.data.hours}
          </span>
        </div>
        <p class="job-summary">{job.data.summary}</p>
        <div class="job-body">
          <Content />
        </div>
      </div>
      <aside class="job-detail-sidebar">
        <div class="sidebar-card">
          <h3>Interessiert?</h3>
          <p>Vereinbare ein unverbindliches Gespräch oder einen Probearbeitstag.</p>
          <GlassButton href="/kontakt">Kennenlernen</GlassButton>
        </div>
        <div class="sidebar-card">
          <h3>Alternativ</h3>
          <p>Schreib uns direkt eine Nachricht.</p>
          <GlassButton variant="secondary" href="/kontakt">Kontakt</GlassButton>
        </div>
      </aside>
    </div>
  </main>
  <Footer />
  <TypebotEmbed />
</BaseLayout>

<style>
  .job-detail {
    padding: 120px 32px 80px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .job-detail-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 40px;
  }
  .back-link {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--primary, #0071bc);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
  }
  .back-link:hover { color: var(--primary-dark, #005894); }
  .job-detail-content {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 48px;
  }
  h1 {
    font-size: clamp(28px, 4vw, 40px);
    margin: 0 0 16px;
    color: var(--on-surface, #191c1d);
  }
  .job-meta {
    display: flex;
    gap: 24px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 15px;
    color: var(--on-surface-variant, #404751);
  }
  .meta-item .material-symbols-outlined {
    font-size: 18px;
    color: var(--primary, #0071bc);
  }
  .job-summary {
    font-size: 18px;
    color: var(--on-surface, #191c1d);
    margin: 0 0 32px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--outline-variant, #c0c7d3);
    line-height: 1.6;
  }
  .job-body {
    font-size: 16px;
    line-height: 1.8;
    color: var(--on-surface, #191c1d);
  }
  .job-body :global(h2) { font-size: 20px; margin: 32px 0 12px; }
  .job-body :global(p) { margin: 0 0 12px; }
  .job-body :global(ul) { padding-left: 20px; }
  .job-body :global(li) { margin-bottom: 8px; }
  .sidebar-card {
    background: var(--glass-bg-medium, rgba(255,255,255,0.75));
    backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border-light, rgba(255,255,255,0.5));
    border-radius: var(--glass-radius-large, 16px);
    padding: 24px;
    margin-bottom: 20px;
  }
  .sidebar-card h3 { font-size: 17px; margin: 0 0 8px; }
  .sidebar-card p { font-size: 14px; color: var(--on-surface-variant, #404751); margin: 0 0 16px; }
  @media (max-width: 900px) {
    .job-detail-content { grid-template-columns: 1fr; }
    .sidebar-card { max-width: 400px; }
  }
  @media (max-width: 640px) { .job-detail { padding: 100px 16px 60px; } }
</style>
