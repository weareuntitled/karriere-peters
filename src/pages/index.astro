---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import HeroSection from '../sections/HeroSection.astro';
import ServicesGridSection from '../sections/ServicesGridSection.astro';
import ProjectGallerySection from '../sections/ProjectGallerySection.astro';
import CtaSection from '../sections/CtaSection.astro';
import GlassButton from '../components/ui/GlassButton.astro';
---
<BaseLayout title="Spenglerei Peters – Ihr Spengler in Kühbach" description="Spenglermeisterbetrieb Peters – Dach, Fassade und Abdichtung in Kühbach und München. Seit 1990 in Familienhand.">
  <Navbar />
  <main>
    <HeroSection />

    <section class="home-about">
      <div class="sp-about-container">
        <div class="sp-about-grid">
          <div class="sp-about-text">
            <span class="sp-about-label">Über uns</span>
            <h2>Seit 1990 in Familienhand</h2>
            <p>Der Spenglermeisterbetrieb Peters wird heute in 2. Generation geführt. Unser Team besteht aus einem Spenglermeister und einem TÜV-geprüften Folientechniker.</p>
            <p>2001 haben wir den Fassadenpreis für Spenglerarbeiten an einer denkmalgeschützten Fassade in der Nymphenburger Straße in München erhalten.</p>
            <a href="/karriere" class="sp-btn-secondary-v2">Mehr über uns</a>
          </div>
          <div class="sp-about-image">
            <img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=800&q=80" alt="Spenglerei Peters Team" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <ProjectGallerySection />

    <CtaSection />
  </main>
  <Footer />
</BaseLayout>

<style>
  .home-about {
    padding: 80px 32px;
    background: #f8f9fa;
  }

  .sp-about-container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .sp-about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .sp-about-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #0071bc;
    display: block;
    margin-bottom: 12px;
  }

  .sp-about-text h2 {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(26px, 3vw, 36px);
    font-weight: 600;
    color: #1a1c1e;
    margin: 0 0 20px;
    line-height: 1.3;
  }

  .sp-about-text p {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.7;
    color: #404751;
    margin: 0 0 16px;
  }

  .sp-btn-secondary-v2 {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 32px;
    background: transparent;
    color: #1a1c1e;
    border: 2px solid #c0c7d3;
    border-radius: 2px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s ease;
    margin-top: 8px;
  }

  .sp-btn-secondary-v2:hover {
    border-color: #0071bc;
    color: #0071bc;
    background: rgba(0, 113, 188, 0.04);
  }

  .sp-about-image img {
    width: 100%;
    border-radius: 16px;
    box-shadow: 0 20px 40px rgba(0, 113, 188, 0.05);
  }

  @media (max-width: 900px) {
    .sp-about-grid { grid-template-columns: 1fr; gap: 32px; }
    .sp-about-image { order: -1; }
  }

  @media (max-width: 640px) {
    .home-about { padding: 60px 16px; }
  }
</style>
