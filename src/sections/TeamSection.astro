---
import { getCollection } from 'astro:content';
import TeamCard from '../components/cards/TeamCard.astro';

const teamMembers = await getCollection('team');
---
<section class="sp-team-section">
  <div class="sp-team-container">
    <div class="sp-team-header">
      <h2>Unser Team</h2>
      <p>Familiär geführt und hochqualifiziert – lernen Sie unser Team kennen.</p>
    </div>
    <div class="sp-team-grid">
      {teamMembers.map((member) => (
        <TeamCard
          name={member.data.title}
          role={member.data.role}
          image={member.data.image}
          cert={member.data.cert}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .sp-team-section { padding: 80px 0; }

  .sp-team-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .sp-team-header { text-align: center; margin-bottom: 48px; }

  .sp-team-header h2 {
    font-family: 'DM Sans', sans-serif;
    font-size: 32px;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: #1a1c1e;
    margin-bottom: 16px;
  }

  .sp-team-header p {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: #404751;
    max-width: 600px;
    margin: 0 auto;
  }

  .sp-team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (max-width: 1024px) { .sp-team-header h2 { font-size: 28px; } }

  @media (max-width: 768px) {
    .sp-team-container { padding: 0 16px; }
    .sp-team-header { margin-bottom: 32px; }
    .sp-team-header h2 { font-size: 28px; }
    .sp-team-grid { grid-template-columns: 1fr; gap: 16px; }
  }

  @media (max-width: 640px) {
    .sp-team-header h2 { font-size: 26px; }
    .sp-team-header p { font-size: 15px; }
  }

  @media (max-width: 480px) { .sp-team-header h2 { font-size: 24px; } }
  @media (max-width: 360px) { .sp-team-header h2 { font-size: 22px; } }
</style>
