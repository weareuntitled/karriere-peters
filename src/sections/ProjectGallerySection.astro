---
const projects = [
  { slug: 'oberfoehring', title: 'Villa Oberföhring', location: 'München', type: 'Fassade', image: '001-oberfoehringerstrasse.jpg', large: true },
  { slug: 'leopolstrasse', title: 'Leopolstraße', location: 'München', type: 'Dach', image: '012-leopolstrasse.jpg' },
  { slug: 'edelweissstrasse', title: 'Edelweißstraße', location: 'München', type: 'Sonderanfertigung', image: '021-edelweissstrasse.jpg' },
  { slug: 'alpenstrasse', title: 'Alpenstraße', location: 'München', type: 'Dach', image: '031-alpenstrasse.jpg', wide: true },
  { slug: 'herrenchiemseestrasse', title: 'Herrenchiemseestraße', location: 'München', type: 'Fassade', image: '008-herrenchiemseestrasse.jpg' },
  { slug: 'poschinger-weiher', title: 'Poschinger Weiher', location: 'München', type: 'Sonderanfertigung', image: '007-poschingerweiher.jpg' },
];
---
<section class="sp-gallery-section">
  <div class="sp-gallery-container">
    <div class="sp-gallery-header">
      <h1>Unsere Meisterwerke</h1>
      <p>Präzision in Metall und Wasser. Entdecken Sie eine Auswahl unserer hochwertigen Spenglerarbeiten.</p>
    </div>

    <div class="sp-gallery-filters">
      <button class="sp-filter-btn active">Alle Projekte</button>
      <button class="sp-filter-btn">Fassaden</button>
      <button class="sp-filter-btn">Dacheindeckungen</button>
      <button class="sp-filter-btn">Sonderanfertigungen</button>
    </div>

    <div class="sp-bento-grid">
      {projects.map((p) => (
        <article class={`sp-bento-item ${p.large ? 'large' : ''} ${p.wide ? 'wide' : ''}`} data-type={p.type}>
          <img src={`/images/${p.image}`} alt={p.title} loading="lazy" />
          <div class="sp-bento-overlay">
            <div class="sp-bento-details">
              <div>
                <span class="sp-bento-tag">{p.type}</span>
                <h3>{p.title}</h3>
              </div>
              <a href={`/projekte#${p.slug}`} class="sp-bento-link">
                Details
                <span class="material-symbols-outlined">arrow_forward</span>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .sp-gallery-section { padding: 80px 0; }
  .sp-gallery-container { max-width: 1280px; margin: 0 auto; padding: 0 32px; }

  .sp-gallery-header { text-align: center; margin-bottom: 48px; }

  .sp-gallery-header h1 {
    font-family: 'DM Sans', sans-serif;
    font-size: 32px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #1a1c1e;
    margin-bottom: 16px;
  }

  .sp-gallery-header p {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: #404751;
    max-width: 600px;
    margin: 0 auto;
  }

  .sp-gallery-filters {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .sp-filter-btn {
    padding: 10px 20px;
    border-radius: 9999px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .sp-filter-btn.active {
    background: #0071bc;
    color: white;
    border: 1px solid #0071bc;
  }

  .sp-filter-btn:not(.active) {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(0, 113, 188, 0.15);
    color: #0071bc;
  }

  .sp-filter-btn:not(.active):hover { background: rgba(255, 255, 255, 0.85); }

  .sp-bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 300px;
    gap: 24px;
  }

  .sp-bento-item {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    cursor: pointer;
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.8);
    box-shadow: 0 8px 32px rgba(0, 113, 188, 0.06);
    transition: all 0.3s ease;
  }

  .sp-bento-item.large { grid-column: span 2; grid-row: span 2; }
  .sp-bento-item.wide { grid-column: span 2; }

  .sp-bento-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .sp-bento-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 64px rgba(0, 113, 188, 0.12);
  }

  .sp-bento-item:hover img { transform: scale(1.05); }

  .sp-bento-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(0, 113, 188, 0.1);
    transform: translateY(100%);
    opacity: 0;
    transition: all 0.3s ease;
  }

  .sp-bento-item:hover .sp-bento-overlay { transform: translateY(0); opacity: 1; }

  .sp-bento-details {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
  }

  .sp-bento-tag {
    display: inline-block;
    padding: 4px 12px;
    background: rgba(0, 113, 188, 0.1);
    border: 1px solid rgba(0, 113, 188, 0.2);
    border-radius: 9999px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #0071bc;
    margin-bottom: 8px;
  }

  .sp-bento-details h3 {
    font-family: 'DM Sans', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: #1a1c1e;
    margin: 0;
  }

  .sp-bento-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: #0071bc;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .sp-bento-link .material-symbols-outlined { font-size: 16px; }

  @media (max-width: 1024px) {
    .sp-bento-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 280px; }
    .sp-bento-item.large { grid-column: span 2; grid-row: span 2; }
    .sp-bento-item.wide { grid-column: span 2; }
  }

  @media (max-width: 768px) {
    .sp-gallery-section { padding: 60px 0; }
    .sp-bento-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 250px; gap: 16px; }
  }

  @media (max-width: 640px) {
    .sp-gallery-container { padding: 0 16px; }
    .sp-gallery-section { padding: 48px 0; }
    .sp-bento-grid { grid-template-columns: 1fr; grid-auto-rows: 220px; }
    .sp-bento-item.large, .sp-bento-item.wide { grid-column: span 1; grid-row: span 1; }
    .sp-bento-overlay { transform: translateY(0); opacity: 1; }
  }

  @media (max-width: 480px) {
    .sp-gallery-filters { gap: 8px; }
    .sp-filter-btn { padding: 8px 16px; font-size: 11px; }
  }
</style>

<script>
  document.querySelectorAll('.sp-filter-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.sp-filter-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
    });
  });
</script>
